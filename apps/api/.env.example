# Neon PostgreSQL — from neon.tech project dashboard (use asyncpg format)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Neon Auth — legacy, not actively used (auth uses /get-session cookie verification)
STACK_SECRET_SERVER_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...   # $15/month plan price ID
STRIPE_CONTACT_FEE_SGD=9900        # SGD 99.00 in cents

# DeepSeek AI (for brand-fit scoring)
DEEPSEEK_API_KEY=sk-...

# Telegram (reporting bot — same as talent_recruitment bot)
TELEGRAM_BOT_TOKEN=...
